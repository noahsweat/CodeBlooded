<!-- Shows success flash messages if any were added on the previous request. -->
<% if (messages && messages.success) { %>
  <!-- Displays success message(s) -->
  <% messages.success.forEach((message) => { %>
    <div class="flash success"><%= message %></div>
  <% }) %>
<% } %>

<!-- Shows error flash messages if any were added on the previous request. -->
<% if (messages && messages.error) { %>
  <!-- Displays error message(s) -->
  <% messages.error.forEach((message) => { %>
    <div class="flash error"><%= message %></div>
  <% }) %>
<% } %>
